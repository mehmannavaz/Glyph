# examples/tee.glyph — copy stdin to stdout AND to a file.
#
# Usage: glyph examples/tee.glyph FILE
# Like Unix `tee`.

(main)
  <if argc() < 2>
    print "usage: glyph tee.glyph FILE"
    exit(1)

  path = argv()[1]
  f = file_open(path, "w")
  <if f == ptr_null()>
    print "tee: cannot open", path
    exit(1)

  (loop)
    line = readln()
    <if line == "">
      stop
    print line
    file_writeln(f, line)
  file_close(f)
