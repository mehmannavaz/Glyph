# tests/14-expr.glyph — expression precedence and operators
(main)
  print "arithmetic:"
  print "  2 + 3 * 4 =", 2 + 3 * 4
  print "  (2 + 3) * 4 =", (2 + 3) * 4
  print "  10 - 2 - 3 =", 10 - 2 - 3
  print "  2 ^ 10 =", 2 ^ 10
  print "  17 % 5 =", 17 % 5
  print "  -5 + 3 =", -5 + 3
  print "  !true =", !true
  print "  !0 =", !0
  print "  !42 =", !42

  print "comparisons:"
  print "  1 < 2 =", 1 < 2
  print "  2 < 1 =", 2 < 1
  print "  2 <= 2 =", 2 <= 2
  print "  3 >= 5 =", 3 >= 5
  print "  1 == 1 =", 1 == 1
  print "  1 != 2 =", 1 != 2

  print "logical:"
  print "  true && false =", true && false
  print "  true || false =", true || false
  print "  false || true =", false || true
  print "  1 && 2 =", 1 && 2
  print "  0 || 3 =", 0 || 3

  print "bitwise:"
  print "  12 & 10 =", 12 & 10
  print "  12 | 10 =", 12 | 10
  print "  1 << 4 =", 1 << 4
  print "  256 >> 2 =", 256 >> 2
