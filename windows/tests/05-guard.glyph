# tests/05-guard.glyph — diamond guard (if/else)

[grade score]
  <if score >= 90>
    return "A"
  else
    <if score >= 80>
      return "B"
    else
      <if score >= 70>
        return "C"
      else
        return "F"

(main)
  print the [grade 95]
  print the [grade 85]
  print the [grade 75]
  print the [grade 50]
