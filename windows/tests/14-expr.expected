arithmetic:
  2 + 3 * 4 = 14
  (2 + 3) * 4 = 20
  10 - 2 - 3 = 5
  2 ^ 10 = 1024
  17 % 5 = 2
  -5 + 3 = -2
  !true = 0
  !0 = 1
  !42 = 0
comparisons:
  1 < 2 = 1
  2 < 1 = 0
  2 <= 2 = 1
  3 >= 5 = 0
  1 == 1 = 1
  1 != 2 = 1
logical:
  true && false = 0
  true || false = 1
  false || true = 1
  1 && 2 = 1
  0 || 3 = 1
bitwise:
  12 & 10 = 8
  12 | 10 = 14
  1 << 4 = 16
  256 >> 2 = 64
