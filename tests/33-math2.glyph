# tests/33-math2.glyph — extended math operations

(main)
  print "gcd(12, 8):", math_gcd(12, 8)
  print "gcd(17, 5):", math_gcd(17, 5)
  print "lcm(4, 6):", math_lcm(4, 6)
  print "fact(5):", math_fact(5)
  print "fact(10):", math_fact(10)
  print "is_prime(2):", math_is_prime(2)
  print "is_prime(17):", math_is_prime(17)
  print "is_prime(18):", math_is_prime(18)
  print "is_prime(97):", math_is_prime(97)
  print "is_prime(100):", math_is_prime(100)
  print "hypot(3, 4):", math_hypot(3.0, 4.0)
  print "deg2rad(180):", math_deg2rad(180.0)
  print "rad2deg(3.14159):", math_rad2deg(3.14159)
  print "comb(10, 3):", math_comb(10, 3)
  print "comb(52, 5):", math_comb(52, 5)
  print "perm(5, 2):", math_perm(5, 2)
  print "perm(10, 3):", math_perm(10, 3)
